# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: override the default model (gpt-4o)
# OPENAI_MODEL=gpt-4o

# Where to deliver the daily briefing
RECIPIENT_EMAIL=your.email@gmail.com

# Email provider: sendgrid (recommended) or gmail
EMAIL_PROVIDER=sendgrid

# SendGrid (free — https://sendgrid.com)
# 1. Sign up free, verify sender email, create API key with Mail Send permission
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDER_EMAIL=your.email@gmail.com

# Gmail SMTP (only if App Passwords are available on your account)
# GMAIL_EMAIL=your.email@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
