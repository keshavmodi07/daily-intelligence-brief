# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# Email
RECIPIENT_EMAIL=you@example.com
FROM_EMAIL=verified-sender@example.com
EMAIL_PROVIDER=sendgrid
EMAIL_SENDER_NAME=Personal Intelligence Platform

# SendGrid
SENDGRID_API_KEY=SG.your-key-here

# Gmail SMTP alternative
GMAIL_EMAIL=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# Brevo SMTP alternative
BREVO_SMTP_LOGIN=your-brevo-smtp-login
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587

# Scouting and cost controls
LOOKBACK_DAYS=2
MEMORY_SUPPRESSION_DAYS=14
MAX_ITEMS_PER_SOURCE=20
MAX_ARTICLES_FOR_EVENT_EXTRACTION=90
MAX_EVENTS_FOR_PROMPT=45
MAX_EVENTS_PER_GROUP=8
EXTRACT_ARTICLE_TEXT=true
ENABLE_TARGETED_FALLBACK_SEARCH=true
OPENAI_WEB_SEARCH_TOOL=web_search_preview
REQUEST_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
